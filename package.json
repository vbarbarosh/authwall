{
  "name": "authwall",
  "author": "Vladimir Barbaros <authwall@vbarbarosh.com>",
  "version": "1.7.1",
  "license": "MIT",
  "main": "src/index.js",
  "private": true,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vbarbarosh/authwall.git"
  },
  "homepage": "https://github.com/vbarbarosh/authwall",
  "bugs": {
    "url": "https://github.com/vbarbarosh/authwall/issues"
  },
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "start": "node .",
    "watch": "nodemon -r dotenv/config .",
    "migrate": "knex migrate:latest --env=sqlite",
    "migrate:make": "knex migrate:make --env=sqlite",
    "migrate:rollback": "knex migrate:rollback --env=sqlite",
    "test": "npm run test:unit && npm run test:api && npm run test:e2e",
    "test:unit": "mocha --no-package --config mocha.unit.js",
    "test:api": "mocha --no-package --config mocha.api.js",
    "test:e2e": "playwright test",
    "test:coverage": "rimraf coverage/tmp && NODE_V8_COVERAGE=coverage/tmp mocha --no-package --config mocha.unit.js ; NODE_V8_COVERAGE=coverage/tmp mocha --no-package --config mocha.api.js ; c8 report"
  },
  "c8": {
    "reporter": [
      "text",
      "html",
      "lcov"
    ],
    "exclude": [
      "db/migrations/**",
      "tests/**",
      "mocha.*.js",
      "config/**",
      "playwright.config.js"
    ]
  },
  "dependencies": {
    "@paralleldrive/cuid2": "^3.3.0",
    "@sentry/node": "^10.50.0",
    "@vbarbarosh/express-helpers": "^2.2.1",
    "@vbarbarosh/node-helpers": "^3.75.0",
    "@vbarbarosh/type-helpers": "^0.2.0",
    "axios": "^1.14.0",
    "bcrypt": "^6.0.0",
    "better-sqlite3": "^12.8.0",
    "bluebird": "^3.7.2",
    "express": "^4.22.1",
    "express-session": "^1.19.0",
    "http-proxy-middleware": "^3.0.5",
    "knex": "^3.1.0",
    "multer": "^2.1.1",
    "mysql2": "^3.19.1",
    "pg": "^8.20.0",
    "sharp": "^0.34.5",
    "yaml": "^2.8.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/node": "^25.5.0",
    "c8": "^11.0.0",
    "dotenv": "^17.3.1",
    "mocha": "^11.7.5",
    "nock": "^14.0.12",
    "nodemon": "^3.1.14",
    "rimraf": "^6.1.3"
  },
  "__mocha__": "The following is just for PhpStorm",
  "mocha": {
    "require": [
      "mocha.api.js"
    ]
  }
}
