#!/bin/bash

# http://www.gnu.org/software/bash/manual/bash.html#The-Set-Builtin
# http://redsymbol.net/articles/unofficial-bash-strict-mode
set -o nounset -o errexit -o pipefail

script=`realpath $0`
scriptdir=`dirname $script`
scriptname=`basename $script`

cd $scriptdir/..

version=${VERSION:-$(node -p "require('./package.json').version")}
revision=${REVISION:-$(git rev-parse --short=12 HEAD)}
source=${SOURCE:-https://github.com/vbarbarosh/authwall}
created=${CREATED:-$(date -u +%FT%TZ)}

if [[ $# -eq 0 ]]; then
    set -- -t vbarbarosh/authwall
fi

docker build \
    --build-arg AUTHWALL_CREATED="$created" \
    --build-arg AUTHWALL_REVISION="$revision" \
    --build-arg AUTHWALL_SOURCE="$source" \
    --build-arg AUTHWALL_VERSION="$version" \
    "$@" .
