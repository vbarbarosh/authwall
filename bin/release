#!/bin/bash

# http://www.gnu.org/software/bash/manual/bash.html#The-Set-Builtin
# http://redsymbol.net/articles/unofficial-bash-strict-mode/
set -o nounset -o errexit -o pipefail

# Pure Git release script.
#
# Role:
#   - run from the clean production branch
#   - bump package version
#   - commit the version bump
#   - create and push the release tag
#
# Responsibility boundaries:
#   - does not run tests
#   - does not build or push Docker images
#   - CI/CD should run bin/test followed by bin/deploy after production is pushed

script=`realpath $0`
scriptdir=`dirname $script`
scriptname=`basename $script`

RED="\e[31m"
GREEN="\e[32m"
RESET="\e[0m"

EXIT_MESSAGE="${RED}bin/release failed${RESET}"
trap 'echo -e $EXIT_MESSAGE' EXIT

cd $scriptdir/..

MERGE_LOCK=$(test -e MERGE_LOCK && cat MERGE_LOCK | grep -v '^#'; true)
if test -n "$MERGE_LOCK"; then
    echo -e "${RED}error: merging master → production was locked${RESET} ⚠️"
    echo -e "${RED}${MERGE_LOCK}${RESET}"
    exit 1
fi

case "${1-}"  in
major|minor|patch)
    ;;
*)
    echo usage: release 'major|minor|patch' >&2
    exit 1
    ;;
esac

if test `git rev-parse --abbrev-ref HEAD` != production; then
    echo error: switch branch to production >&2
    exit 1
fi

if test -n "`git status -s`"; then
    echo error: there is changes >&2
    exit 1
fi

# Increase a version without commiting it and making a tag
npm version $1 --no-git-tag-version

# Building a frontend
# export SENTRY_RELEASE=v$(node -e 'console.log(require("./package.json").version)')
# npm run prod

git add package.json
if test -e package-lock.json; then
    git add package-lock.json
fi
git commit -m "release v$(node -e 'console.log(require("./package.json").version)')"

# Create a tag
tag=v$(node -e 'console.log(require("./package.json").version)')
git tag $tag

git push origin production
git push origin $tag

EXIT_MESSAGE="${GREEN}bin/release succeeded${RESET}"
