#!/usr/bin/env node

const als = require('../src/helpers/als');
const cli = require('@vbarbarosh/node-helpers/src/cli');
const config = require('../config');
const knex = require('knex');
const {
    load_activity_summary_events,
    parse_activity_summary_args,
    render_activity_summary,
    summarize_activity_events,
    usage,
} = require('../src/helpers/render/render_activity_summary');

cli(main);

async function main()
{
    const options = parse_activity_summary_args(process.argv.slice(2));

    if (options.help) {
        process.stdout.write(usage().join('\n') + '\n');
        return;
    }

    const db = knex(config.knexvars);
    await using _ = {[Symbol.asyncDispose]: () => db.destroy()};

    const events = await als.run({db}, () => load_activity_summary_events(options))
    const summary = summarize_activity_events(events, options);

    if (options.json) {
        process.stdout.write(JSON.stringify(summary, null, 2) + '\n');
        return;
    }

    process.stdout.write(render_activity_summary(summary).join('\n') + '\n');
}
